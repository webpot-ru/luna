{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-codex-workflow-safety.mjs --pretool",
            "timeout": 10,
            "statusMessage": "Checking LunaCards command safety"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-codex-workflow-safety.mjs --hook",
            "timeout": 30,
            "statusMessage": "Checking LunaCards workflow safety"
          }
        ]
      }
    ]
  }
}
